{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"skipLibCheck": true,

		/* Bundler mode (Vite) */
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",

		/* Incremental adoption: remaining .js/.jsx files keep working */
		"allowJs": true,
		"checkJs": false,

		/* Linting */
		"strict": true,
		"noFallthroughCasesInSwitch": true,

		"types": ["vite/client"]
	},
	"include": ["src"]
}
